+                    (void)pci_read_config_dword(root_pdev, root_aer_pos2 + PCI_ERR_UNCOR_MASK,   &root_uemsk2);
+                    (void)pci_read_config_dword(root_pdev, root_aer_pos2 + PCI_ERR_COR_STATUS,   &root_cesta2);
+                    (void)pci_read_config_dword(root_pdev, root_aer_pos2 + PCI_ERR_COR_MASK,     &root_cemsk2);
+                    (void)pci_read_config_dword(root_pdev, root_aer_pos2 + PCI_ERR_ROOT_STATUS,  &root_rootsta2);
