index a5fda94c..bc59c1a4 100644
--- a/version.mk
+++ b/version.mk
@@ -1,4 +1,4 @@
-NVIDIA_VERSION = 595.71.05-aorus.7
+NVIDIA_VERSION = 595.71.05-aorus.8
 NVIDIA_NVID_VERSION = 595.71.05
 NVIDIA_NVID_EXTRA = 
 
