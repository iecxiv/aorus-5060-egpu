  * Reads the GSP MMU WPR2 status register via a temporary ioremap of a
--- a/kernel-open/nvidia-uvm/uvm.c
+++ b/kernel-open/nvidia-uvm/uvm.c
@@ -31,6 +31,59 @@
 #include "uvm_va_space_mm.h"
 #include "uvm_va_range.h"
 #include "uvm_va_block.h"
+
+/* AORUS Patch 0030 (2026-05-08): UVM close-path DIAG instrumentation.
+ *
+ * Imports the pdev-based DIAG dump from nvidia.ko. Used to capture
+ * GPU state across UVM open/close lifecycle points so we can answer
+ * "is the UVM close-path bug class (architecture.md Problem 4) still
+ * load-bearing on the current driver stack?" with empirical evidence
+ * — the same way Patch 0029's close-path-probe.sh answered the
+ * /dev/nvidia0-side question. */
+#include <linux/pci.h>
+#include <linux/atomic.h>
+extern void tb_egpu_lever_m_diag_dump_pdev(struct pci_dev *pdev, const char *site);
+extern void tb_egpu_dump_aer_trigger_event(struct pci_dev *gpu_pdev,
+                                          const char *trigger,
+                                          void *out);
+
+/* Global UVM fd refcount — incremented in uvm_open, decremented in
+ * uvm_release. LAST-CLOSE detection: when the post-decrement value is 0,
+ * trigger full DIAG+AER state capture. Atomic so no lock needed. */
+static atomic_t aorus_uvm_fd_count = ATOMIC_INIT(0);
+
+/* Look up the GPU's pci_dev. Hardcoded BDF 0000:04:00.0 per project
+ * topology (only NVIDIA device on this host). Returns NULL if absent.
+ * Caller does NOT need to pci_dev_put — pci_get_domain_bus_and_slot
+ * increments refcount but for our DIAG snapshot use we only need the
+ * pointer momentarily. We pci_dev_put after each use to be safe. */
+static struct pci_dev *aorus_uvm_get_gpu_pdev(void)
+{
+    return pci_get_domain_bus_and_slot(0, 0x04, PCI_DEVFN(0, 0));
+}
+
+/* DIAG marker — always emits a one-line log with site + fd_count.
+ * On is_last_close (post-decrement count==0 OR pre-increment count==0),
+ * additionally calls the pdev-based DIAG dump and AER snapshot. */
+static void aorus_uvm_close_path_diag(const char *site, int fd_count, bool is_last_close)
+{
+    struct pci_dev *pdev;
+
+    pr_info("AORUS UVM [CLOSE]: site=%-18s fd_count=%d%s\n",
+            site, fd_count, is_last_close ? " (LAST-CLOSE)" : "");
+
+    if (is_last_close) {
+        pdev = aorus_uvm_get_gpu_pdev();
+        if (pdev) {
+            tb_egpu_lever_m_diag_dump_pdev(pdev, site);
+            tb_egpu_dump_aer_trigger_event(pdev, site, NULL);
+            pci_dev_put(pdev);
+        } else {
+            pr_info("AORUS UVM [CLOSE]: site=%s — no pdev for 0000:04:00.0; skipping DIAG\n",
+                    site);
+        }
+    }
+}
 #include "uvm_tools.h"
 #include "uvm_common.h"
 #include "uvm_fd_type.h"
@@ -175,6 +228,16 @@
     filp->private_data = NULL;
     filp->f_mapping = mapping;
 
+    /* AORUS Patch 0030: uvm-open-entry DIAG site. We increment the
+     * fd_count only at success — the kernel only calls uvm_release for
+     * fds that this function returned NV_OK for. If pre-increment
+     * fd_count was 0, this open is "first-after-LAST-CLOSE" — capture
+     * full DIAG+AER state. */
+    {
+        int prev = atomic_inc_return(&aorus_uvm_fd_count) - 1;
+        aorus_uvm_close_path_diag("uvm-open-entry", prev + 1, prev == 0);
+    }
+
     return NV_OK;
 }
 
@@ -252,13 +315,36 @@
     void *ptr;
     uvm_fd_type_t fd_type = uvm_fd_type(filp, &ptr);
 
+    /* AORUS Patch 0030: uvm-release-entry DIAG site. Pre-decrement
+     * fd_count is the "current" count. If it's 1, this release is
+     * about to drive the count to 0 — LAST-CLOSE. Capture full DIAG
+     * before any teardown work runs. */
+    {
+        int pre_count = atomic_read(&aorus_uvm_fd_count);
+        aorus_uvm_close_path_diag("uvm-release-entry", pre_count, pre_count == 1);
+    }
+
     switch (fd_type) {
         case UVM_FD_UNINITIALIZED:
             uvm_kvfree(filp->f_mapping);
             break;
 
         case UVM_FD_VA_SPACE:
+            /* AORUS Patch 0030: pre-destroy DIAG — captures state
+             * immediately before uvm_va_space_destroy runs (the actual
+             * destabilising teardown). */
+            {
+                int pre_count = atomic_read(&aorus_uvm_fd_count);
+                aorus_uvm_close_path_diag("uvm-pre-destroy", pre_count, pre_count == 1);
+            }
             uvm_release_va_space(filp, (uvm_va_space_t *)ptr);
+            /* AORUS Patch 0030: post-destroy DIAG — captures state
+             * AFTER uvm_va_space_destroy. Diff vs pre-destroy reveals
+             * the close-path's hardware/firmware footprint. */
+            {
+                int pre_count = atomic_read(&aorus_uvm_fd_count);
+                aorus_uvm_close_path_diag("uvm-post-destroy", pre_count, pre_count == 1);
+            }
             break;
 
         case UVM_FD_MM:
@@ -273,6 +359,15 @@
             UVM_ASSERT_MSG(0, "Unexpected fd type: %d\n", fd_type);
     }
 
+    /* AORUS Patch 0030: uvm-release-exit DIAG site. Now decrement
+     * fd_count — kernel guarantees this release matches a prior
+     * successful open. Post-decrement count==0 is the
+     * canonical-LAST-CLOSE state. */
+    {
+        int post = atomic_dec_return(&aorus_uvm_fd_count);
+        aorus_uvm_close_path_diag("uvm-release-exit", post, post == 0);
+    }
+
     return 0;
 }
 
