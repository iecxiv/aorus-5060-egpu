+/* Patch 0030 (2026-05-08): pdev-based DIAG dump for cross-module callers.
+ *
+ * Callable from nvidia-uvm.ko (and any other future module that doesn't
+ * have nv_linux_state_t access) for state capture at UVM lifecycle
+ * points. Reads BAR0 directly from pdev->resource[0].start (kernel's
+ * PCI resource table) instead of nvl->bars, then performs the same
+ * PMC_BOOT_0 + WPR2 + LnkSta + AER captures as tb_egpu_lever_m_diag_dump.
+ * Output uses an [UVM-DIAG] tag so dmesg distinguishes from the
+ * /dev/nvidia0-side [DIAG] events.
+ *
+ * The pdev argument is the GPU's pci_dev. UVM looks it up via
+ * pci_get_domain_bus_and_slot() since it doesn't have nvl access.
+ */
+void tb_egpu_lever_m_diag_dump_pdev(struct pci_dev *pdev, const char *site)
+{
+    struct pci_dev *parent;
+    void __iomem *map_pmc;
+    void __iomem *map_wpr2;
+    u64           bar0_phys;
+    u64           wpr2_page_aligned;
+    u32           wpr2_page_offset;
+    u32           pmc_boot_0 = 0xdeadbeefu;
+    u32           wpr2_raw   = 0xdeadbeefu;
+    bool          pmc_ok = false, wpr2_ok = false;
+    u16 gpu_lnksta = 0xffff, br_lnksta = 0xffff;
+    u32 gpu_aer_unc = 0, gpu_aer_cor = 0;
+    u32 br_aer_unc = 0, br_aer_cor = 0;
+    int gpu_aer_pos = 0, br_aer_pos = 0;
+
+    if (!pdev) {
+        nv_printf(NV_DBG_ERRORS,
+            "AORUS Lever M-recover [UVM-DIAG]: site=%s pdev=NULL — cannot read\n",
+            site);
+        return;
+    }
+
+    bar0_phys = pci_resource_start(pdev, 0);
+    if (bar0_phys == 0) {
+        nv_printf(NV_DBG_ERRORS,
+            "AORUS Lever M-recover [UVM-DIAG]: site=%s bar0=0 — skipping\n",
+            site);
+        return;
+    }
+
+    /* PMC_BOOT_0 */
+    map_pmc = ioremap(bar0_phys, PAGE_SIZE);
+    if (map_pmc) {
+        pmc_boot_0 = ioread32(map_pmc);
+        iounmap(map_pmc);
+        pmc_ok = true;
+    }
+
+    /* WPR2_ADDR_HI */
+    wpr2_page_aligned = (bar0_phys + TB_EGPU_LEVER_M_WPR2_REG_OFFSET) & PAGE_MASK;
+    wpr2_page_offset  = (bar0_phys + TB_EGPU_LEVER_M_WPR2_REG_OFFSET) & ~PAGE_MASK;
+    map_wpr2 = ioremap(wpr2_page_aligned, PAGE_SIZE);
+    if (map_wpr2) {
+        wpr2_raw = ioread32(map_wpr2 + wpr2_page_offset);
+        iounmap(map_wpr2);
+        wpr2_ok = true;
+    }
+
+    /* LnkSta + AER on GPU + parent bridge. Pure config-space reads. */
+    parent = pci_upstream_bridge(pdev);
+    (void)pcie_capability_read_word(pdev, PCI_EXP_LNKSTA, &gpu_lnksta);
+    gpu_aer_pos = pci_find_ext_capability(pdev, PCI_EXT_CAP_ID_ERR);
+    if (gpu_aer_pos) {
+        (void)pci_read_config_dword(pdev, gpu_aer_pos + PCI_ERR_UNCOR_STATUS, &gpu_aer_unc);
+        (void)pci_read_config_dword(pdev, gpu_aer_pos + PCI_ERR_COR_STATUS,   &gpu_aer_cor);
+    }
+    if (parent) {
+        (void)pcie_capability_read_word(parent, PCI_EXP_LNKSTA, &br_lnksta);
+        br_aer_pos = pci_find_ext_capability(parent, PCI_EXT_CAP_ID_ERR);
+        if (br_aer_pos) {
+            (void)pci_read_config_dword(parent, br_aer_pos + PCI_ERR_UNCOR_STATUS, &br_aer_unc);
+            (void)pci_read_config_dword(parent, br_aer_pos + PCI_ERR_COR_STATUS,   &br_aer_cor);
+        }
+    }
+
+    nv_printf(NV_DBG_ERRORS,
+        "AORUS Lever M-recover [UVM-DIAG]: site=%-18s pdev=%s bar0=0x%llx "
+        "PMC_BOOT_0=%s%08x WPR2=%s%08x WPR2_up=%s parent=%s "
+        "GPU_LnkSta=0x%04x(Speed=%u Width=x%u Active=%c) "
+        "Br_LnkSta=0x%04x(Speed=%u Width=x%u Active=%c) "
+        "GPU_AER_Unc=0x%08x Cor=0x%08x Br_AER_Unc=0x%08x Cor=0x%08x\n",
+        site, pci_name(pdev),
+        (unsigned long long)bar0_phys,
+        pmc_ok ? "0x" : "MAPFAIL:", pmc_boot_0,
+        wpr2_ok ? "0x" : "MAPFAIL:", wpr2_raw,
+        ((wpr2_raw & TB_EGPU_LEVER_M_WPR2_VAL_MASK) != 0) ? "YES" : "no",
+        parent ? pci_name(parent) : "NULL",
+        gpu_lnksta,
+        (gpu_lnksta & PCI_EXP_LNKSTA_CLS),
+        (gpu_lnksta & PCI_EXP_LNKSTA_NLW) >> 4,
+        (gpu_lnksta & PCI_EXP_LNKSTA_DLLLA) ? 'Y' : 'N',
+        br_lnksta,
+        (br_lnksta & PCI_EXP_LNKSTA_CLS),
+        (br_lnksta & PCI_EXP_LNKSTA_NLW) >> 4,
+        (br_lnksta & PCI_EXP_LNKSTA_DLLLA) ? 'Y' : 'N',
+        gpu_aer_unc, gpu_aer_cor, br_aer_unc, br_aer_cor);
+
+    (void)gpu_aer_pos; (void)br_aer_pos;
+}
+EXPORT_SYMBOL(tb_egpu_lever_m_diag_dump_pdev);
+
 /* Commit 2: probe-time WPR2-stuck detection.
