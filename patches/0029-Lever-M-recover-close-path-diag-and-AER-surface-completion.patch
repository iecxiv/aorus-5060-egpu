  * callback. Walks GPU -> bridge -> root_port (via aorus_walk_to_root_port
--- a/kernel-open/nvidia/nv-lever-m-recover.c
+++ b/kernel-open/nvidia/nv-lever-m-recover.c
@@ -1185,6 +1185,52 @@
 }
 EXPORT_SYMBOL(tb_egpu_lever_m_record_post_rminit_ok);
 
+/* Patch 0029 (2026-05-08): close-path DIAG marker + last-close full dump.
+ *
+ * Companion to the existing 4 open-side DIAG sites. Always emits a
+ * one-line marker logging usage_count at the call site. On the
+ * last-close path (caller passes is_last_close=true), additionally
+ * calls tb_egpu_lever_m_diag_dump and tb_egpu_dump_aer_trigger_event for
+ * the full state + AER snapshot — the diff between this and the
+ * preceding open-side DIAG entries is the close path's hardware/
+ * firmware footprint, which is what we need to diagnose the close-path
+ * bug class (architecture.md Problem 2 + Problem 4).
+ *
+ * Passive: uses the existing diag_dump (ioremap+ioread32+iounmap, no
+ * DMA) and tb_egpu_dump_aer_trigger_event (PCI config-space reads only).
+ * Both have been live since 2026-05-06 in DIAG sites without perturbing
+ * observed behaviour. Per feedback_observability_perturbs_bug, verify
+ * via baseline-vs-instrumented comparison if the close path is observed
+ * to behave differently after this patch lands.
+ */
+void tb_egpu_lever_m_close_path_diag(nv_linux_state_t *nvl,
+                                    const char *site,
+                                    long usage_count,
+                                    bool is_last_close)
+{
+    nv_state_t *nv;
+
+    if (!nvl)
+        return;
+
+    nv = NV_STATE_PTR(nvl);
+
+    NV_DEV_PRINTF(NV_DBG_ERRORS, nv,
+        "AORUS Lever M-recover [CLOSE]: site=%-15s usage_count=%ld%s\n",
+        site, usage_count, is_last_close ? " (LAST-CLOSE)" : "");
+
+    if (is_last_close)
+    {
+        /* Full state dump + AER snapshot. Same helper used by the open
+         * side, so the dmesg format is consistent across both halves of
+         * the open->close lifecycle. */
+        tb_egpu_lever_m_diag_dump(nvl, site);
+        if (nvl->pci_dev)
+            tb_egpu_dump_aer_trigger_event(nvl->pci_dev, site, NULL);
+    }
+}
+EXPORT_SYMBOL(tb_egpu_lever_m_close_path_diag);
+
 int tb_egpu_lever_m_recover_init(nv_linux_state_t *nvl)
