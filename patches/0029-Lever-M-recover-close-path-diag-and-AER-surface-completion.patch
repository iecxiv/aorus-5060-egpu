+/* Patch 0029 (2026-05-08): close-path DIAG marker.
+ *
+ * Extends the open-side DIAG infrastructure (probe-end / startdev-entry
+ * / pre-rmInit / post-rmInit-{OK,FAIL}) into the close path. Lets us
+ * capture state diff across the open->work->close->reopen lifecycle,
+ * which is what we need to diagnose the close-path-bug class
+ * (architecture.md Problem 2 + Problem 4).
+ *
+ * Behaviour:
+ *   - Always emits a one-line marker logging usage_count at the site.
+ *   - On the "last close" path (usage_count==0 after decrement, or about
+ *     to be 0 going in), additionally calls tb_egpu_lever_m_diag_dump
+ *     and tb_egpu_dump_aer_trigger_event for full state + AER capture.
+ *   - Cheap when the call is NOT a last-close (e.g. persistenced still
+ *     holds an fd) — just one printk line.
+ *
+ * Sites (called from nv.c):
+ *   - close-entry      — entry of nvidia_close_callback
+ *   - pre-stop         — after usage_count decremented to 0, before nv_stop_device
+ *   - post-shutdown    — inside nv_stop_device after rm_disable/nv_shutdown_adapter
+ *   - close-exit       — end of nvidia_close_callback
+ *
+ * `is_last_close` parameter — caller's determination. true means do
+ * full DIAG + AER dump. false means just the marker line.
+ */
+void tb_egpu_lever_m_close_path_diag(nv_linux_state_t *nvl,
+                                    const char *site,
+                                    long usage_count,
+                                    bool is_last_close);
