 }
 
+/* AORUS Lever M-recover Patch 0029 (2026-05-08): mmio_enabled callback.
+ *
+ * Called by the kernel between error_detected returning CAN_RECOVER
+ * and slot_reset, to give the driver a chance to do passive MMIO
+ * probing. We currently always return NEED_RESET from error_detected
+ * (H4 path), so the kernel's normal flow won't dispatch mmio_enabled —
+ * but kernel internals occasionally invoke it via pci_walk_bus during
+ * AER recovery. Wiring it up:
+ *   (a) closes the err_handlers callback surface for completeness,
+ *   (b) gives us observability if the kernel ever does call it,
+ *   (c) future-proofs against kernel API changes.
+ *
+ * Body: dump DIAG + AER snapshot, return RECOVERED (we have no special
+ * MMIO test to run). */
+static pci_ers_result_t nv_pci_mmio_enabled(struct pci_dev *pci_dev)
+{
+    nv_linux_state_t *nvl = pci_get_drvdata(pci_dev);
+
+    nv_printf(NV_DBG_ERRORS,
+              "AORUS Lever M-recover: mmio_enabled callback fired on %s\n",
+              pci_name(pci_dev));
+
+    if (nvl) {
+        tb_egpu_lever_m_diag_dump(nvl, "mmio-enabled");
+        tb_egpu_dump_aer_trigger_event(pci_dev, "mmio-enabled", NULL);
+    }
+
+    return PCI_ERS_RESULT_RECOVERED;
+}
+
+/* AORUS Lever M-recover Patch 0029 (2026-05-08): cor_error_detected
+ * callback. Proactive observability for correctable AER errors that
+ * don't reach the uncorrectable path. The Gen3 demotion observed
+ * 2026-05-07 (Br_AER_Cor=0x1 + GPU_AER_UncMsk=0x400000 demoting
+ * Internal Error to Cor=0x2000) is the kind of correctable that
+ * normally doesn't surface — this callback dumps the AER snapshot at
+ * the moment the kernel sees a Cor fire, giving us a leading
+ * indicator before things escalate to uncorrectable.
+ *
+ * No state change, no recovery action — pure observability. */
+static void nv_pci_cor_error_detected(struct pci_dev *pci_dev)
+{
+    nv_printf(NV_DBG_ERRORS,
+              "AORUS Lever M-recover: cor_error_detected callback fired on %s\n",
+              pci_name(pci_dev));
+
+    tb_egpu_dump_aer_trigger_event(pci_dev, "cor-error", NULL);
+}
+
 static const struct pci_error_handlers nv_pci_err_handlers = {
-    .error_detected = nv_pci_error_detected,
-    .slot_reset     = nv_pci_slot_reset,
-    .resume         = nv_pci_resume,
+    .error_detected     = nv_pci_error_detected,
+    .mmio_enabled       = nv_pci_mmio_enabled,
+    .slot_reset         = nv_pci_slot_reset,
+    .resume             = nv_pci_resume,
+    .cor_error_detected = nv_pci_cor_error_detected,
 };
 
 struct pci_driver nv_pci_driver = {
