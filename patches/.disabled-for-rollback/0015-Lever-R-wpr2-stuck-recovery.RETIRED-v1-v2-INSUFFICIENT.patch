+//
+// AORUS Lever R (Tier 1 v2, 2026-05-06): wrapper around the kernel's
+// pci_reset_function() exposing it to RM-side code. _kgspBootGspRm
+// calls this when WPR2 is detected stuck at probe.
+//
+// Why pci_reset_function instead of pcie_reset_flr (which NVIDIA's
+// existing os_pci_trigger_flr uses)?
+//
+// Empirical evidence 2026-05-06 09:00 (boot-init-mode-b dossier):
+// pcie_reset_flr was forced (despite pending transactions) but did
+// NOT clear WPR2. The kernel logged "PCI FLR might have failed."
+//
+// pci_reset_function is the kernel's escalating-reset wrapper:
+//   1. Try FLR
+//   2. Try PM reset (if device supports)
+//   3. Try slot reset (PCIe bus-level)
+//   4. Try bus reset
+//
+// recovery-mechanism-findings.md validated that
+// `echo 1 > /sys/.../reset` clears WPR2 — and that sysfs entry maps
+// to pci_reset_function, not pcie_reset_flr. Our Lever R primitive
+// must match what worked empirically.
+//
+// Returns NV_OK on success, NV_ERR_GENERIC on failure.
+//
+NV_STATUS NV_API_CALL os_pci_reset_function(
+    void *handle
+)
+{
+    struct pci_dev *pdev = (struct pci_dev *) handle;
+    int err;
+
+    if (!pdev)
+        return NV_ERR_INVALID_ARGUMENT;
+
+    err = pci_reset_function(pdev);
+    if (err != 0)
+    {
+        printk(KERN_ERR
+            "NVRM: AORUS Lever R: pci_reset_function returned %d\n", err);
+        return NV_ERR_GENERIC;
+    }
+
+    return NV_OK;
+}
