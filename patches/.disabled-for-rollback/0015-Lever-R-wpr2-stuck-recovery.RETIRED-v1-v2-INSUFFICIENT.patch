+        //
+        // AORUS Lever R (Tier 1 v2, 2026-05-06): WPR2 left over from a
+        // prior session blocks GSP boot here. On this hardware, WPR2
+        // can persist across host poweroff/poweron and even multi-minute
+        // eGPU AC disconnect (validated 2026-05-06).
+        //
+        // Mechanism: log + call os_pci_reset_function() (kernel-open
+        // wrapper around pci_reset_function which escalates through
+        // FLR → PM → slot → bus reset) + brief settle delay + re-check
+        // WPR2. On success, fall through to normal GSP boot. On failure,
+        // surrender to the original error path.
+        //
+        // v2 specifically uses os_pci_reset_function (pci_reset_function)
+        // rather than os_pci_trigger_flr (pcie_reset_flr) because the
+        // 2026-05-06 09:00 boot-init failure showed pcie_reset_flr alone
+        // does not clear WPR2 on this hardware ("PCI FLR might have
+        // failed" + WPR2 still up). pci_reset_function escalates to
+        // additional reset mechanisms automatically.
+        //
+        // See docs/lever-R-design.md for the full three-tier strategy.
+        // Hypothesis H13 in docs/reliability-hypothesis-ledger.md.
+        //
+        nv_state_t *nv = NV_GET_NV_STATE(pGpu);
+
+        NV_PRINTF(LEVEL_ERROR,
+                  "AORUS Lever R: WPR2-stuck detected at probe — attempting reset (pci_reset_function)\n");
+
+        if (nv != NULL && os_pci_reset_function(nv->handle) == NV_OK)
+        {
+            // pci_reset_function takes ~100-500ms depending on which
+            // reset mechanism succeeded. 500ms safety margin.
+            os_delay(500);
+
+            if (!kgspIsWpr2Up_HAL(pGpu, pKernelGsp))
+            {
+                NV_PRINTF(LEVEL_ERROR,
+                          "AORUS Lever R: WPR2 cleared by reset — proceeding with GSP boot\n");
+                // Fall through to normal GSP init below.
+            }
+            else
+            {
+                NV_PRINTF(LEVEL_ERROR,
+                          "AORUS Lever R: reset completed but WPR2 still up — surrendering\n");
+                NV_PRINTF(LEVEL_ERROR, "unexpected WPR2 already up, cannot proceed with booting GSP\n");
+                NV_PRINTF(LEVEL_ERROR, "(the GPU is likely in a bad state and may need to be reset)\n");
+                return NV_ERR_INVALID_STATE;
+            }
+        }
+        else
+        {
+            NV_PRINTF(LEVEL_ERROR,
+                      "AORUS Lever R: os_pci_reset_function failed (nv=%p) — surrendering\n",
+                      nv);
+            NV_PRINTF(LEVEL_ERROR, "unexpected WPR2 already up, cannot proceed with booting GSP\n");
+            NV_PRINTF(LEVEL_ERROR, "(the GPU is likely in a bad state and may need to be reset)\n");
+            return NV_ERR_INVALID_STATE;
+        }
