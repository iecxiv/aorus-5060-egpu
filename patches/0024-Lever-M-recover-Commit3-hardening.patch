+/* H4 (uevent emission) — emit TB_EGPU_GPU_STATE=<state> uevent on the
+ * pdev's kobject. Used to notify userspace subscribers (udev rules,
+ * services) of recovery lifecycle transitions. */
+void tb_egpu_lever_m_emit_uevent(struct pci_dev *pdev, const char *state)
+{
+    char  envbuf[64];
+    char *envp[2] = { envbuf, NULL };
+
+    if (!pdev || !state)
+        return;
+
+    /* scnprintf is bounded; envbuf is more than enough for the longest
+     * state string ("PERMANENT_FAIL"). */
+    (void)scnprintf(envbuf, sizeof(envbuf), "TB_EGPU_GPU_STATE=%s", state);
+
+    (void)kobject_uevent_env(&pdev->dev.kobj, KOBJ_CHANGE, envp);
+}
+EXPORT_SYMBOL(tb_egpu_lever_m_emit_uevent);
