+/* Commit 3 (Patch 0024): post-rmInit-FAIL trigger.
+ *
+ * Called from nv_start_device() right after rm_init_adapter returns
+ * failure. Reads WPR2 via the same mechanism as the probe-time check
+ * (Commit 2), then runs the H1/H2 gates and schedules the recovery
+ * work item.
+ *
+ * Returns 0 in all cases. Caller continues to its existing failure
+ * path (rc = -EIO; goto failed_release_irq) regardless. Recovery
+ * happens asynchronously on the kernel-global workqueue.
+ *
+ * H1 logic:
+ *   - if SurrenderResetSec idle elapsed since last_fire_jiffies:
+ *       reset attempt_count to 0 (this is a fresh burst)
+ *   - atomic_inc_return; if > MaxAttempts: surrender + emit
+ *     PERMANENT_FAIL; do NOT schedule
+ *
+ * H2 logic:
+ *   - if elapsed_ms < MinAttemptIntervalMs: rate-limit; do NOT
+ *     schedule, do NOT increment attempt_count (we never "tried")
+ *
+ * Re-entry guard:
+ *   - in_progress flag set when we schedule_work; cleared at handler
+ *     completion. If already set, skip (the previous attempt is still
+ *     running; let it finish).
+ */
+int tb_egpu_lever_m_trigger_post_rminit_fail(nv_linux_state_t *nvl)
+{
+    struct tb_egpu_lever_m_recover *lm;
+    nv_state_t *nv;
+    struct pci_dev *pdev;
+    u64 bar0_phys;
+    void __iomem *tmp_map;
+    u64 page_aligned_phys;
+    u32 page_offset;
+    u32 wpr2_raw = 0, wpr2_val = 0;
+    bool wpr2_stuck = false;
+    unsigned long elapsed_ms;
+    int attempts;
+
+    if (!nvl)
+        return 0;
+
+    if (!NVreg_TbEgpuLeverMRecoverEnable || !nvl->lever_m)
+        return 0;   /* M-base fallback: leave existing path in place */
+
+    lm   = nvl->lever_m;
+    nv   = NV_STATE_PTR(nvl);
+    pdev = nvl->pci_dev;
+    bar0_phys = nv->bars[NV_GPU_BAR_INDEX_REGS].cpu_address;
+
+    if (!pdev || bar0_phys == 0)
+        return 0;
+
+    /* Step 1: read WPR2 (or honour TestForceTrigger). */
+    page_aligned_phys = (bar0_phys + TB_EGPU_LEVER_M_WPR2_REG_OFFSET) & PAGE_MASK;
+    page_offset       = (bar0_phys + TB_EGPU_LEVER_M_WPR2_REG_OFFSET) & ~PAGE_MASK;
+
+    tmp_map = ioremap(page_aligned_phys, PAGE_SIZE);
+    if (tmp_map)
+    {
+        wpr2_raw = ioread32(tmp_map + page_offset);
+        iounmap(tmp_map);
+        wpr2_val = wpr2_raw & TB_EGPU_LEVER_M_WPR2_VAL_MASK;
+    }
+    wpr2_stuck = (wpr2_val != 0);
+
+    if (NVreg_TbEgpuLeverMTestForceTrigger && !wpr2_stuck)
+    {
+        NV_DEV_PRINTF(NV_DBG_ERRORS, nv,
+            "AORUS Lever M-recover: TestForceTrigger=1 — forcing trigger "
+            "even though WPR2 is clear (raw=0x%08x)\n", wpr2_raw);
+        wpr2_stuck = true;
+    }
+
+    if (!wpr2_stuck)
+    {
+        NV_DEV_PRINTF(NV_DBG_INFO, nv,
+            "AORUS Lever M-recover: post-rmInit-FAIL but WPR2 clear "
+            "(raw=0x%08x); not the WPR2-stuck failure mode; not triggering\n",
+            wpr2_raw);
+        return 0;
+    }
+
+    /* Step 2: re-entry guard. */
+    if (atomic_xchg(&lm->in_progress, 1) != 0)
+    {
+        NV_DEV_PRINTF(NV_DBG_ERRORS, nv,
+            "AORUS Lever M-recover: trigger fired but in_progress=1; "
+            "previous attempt still running; skipping\n");
+        return 0;
+    }
+
+    /* Step 3: H1 burst-boundary reset — if idle longer than
+     * SurrenderResetSec, treat as a fresh burst. */
+    if (lm->last_fire_jiffies != 0 &&
+        time_after(jiffies,
+                   lm->last_fire_jiffies +
+                   msecs_to_jiffies(NVreg_TbEgpuLeverMSurrenderResetSec * 1000U)))
+    {
+        NV_DEV_PRINTF(NV_DBG_ERRORS, nv,
+            "AORUS Lever M-recover: idle > %us since last fire; "
+            "resetting attempt_count to 0 (fresh burst)\n",
+            NVreg_TbEgpuLeverMSurrenderResetSec);
+        atomic_set(&lm->attempt_count, 0);
+    }
+
+    /* Step 4: H2 rate-limit gate. */
+    if (lm->last_fire_jiffies != 0)
+    {
+        elapsed_ms = jiffies_to_msecs(jiffies - lm->last_fire_jiffies);
+        if (elapsed_ms < NVreg_TbEgpuLeverMMinAttemptIntervalMs)
+        {
+            NV_DEV_PRINTF(NV_DBG_ERRORS, nv,
