+        "AORUS Lever M-recover: scheduling recovery (attempt=%d/%u, "
+        "WPR2=0x%08x, ForceTrigger=%u, fires=%d)\n",
+        attempts, NVreg_TbEgpuLeverMMaxAttempts, wpr2_raw,
+        NVreg_TbEgpuLeverMTestForceTrigger,
+        atomic_read(&lm->fire_count));
