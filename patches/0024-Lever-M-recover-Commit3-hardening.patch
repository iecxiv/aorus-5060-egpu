+/* Commit 3 (H4): pci_error_handlers slot_reset helper.
+ *
+ * Called from nv_pci_slot_reset() in nv-pci.c after the kernel has
+ * driven a bus reset (in response to NEED_RESET from error_detected).
+ * Verifies the GPU is alive on the bus by reading PMC_BOOT_0; if
+ * 0xffffffff, the bus is still down and we DISCONNECT (giving up the
+ * recovery attempt). Otherwise RECOVERED — the kernel will then call
+ * the resume callback. */
+pci_ers_result_t tb_egpu_lever_m_slot_reset(struct pci_dev *pdev)
+{
+    nv_linux_state_t *nvl;
+    nv_state_t *nv;
+    void __iomem *tmp_map;
+    u64 bar0_phys;
+    u32 pmc_boot_0 = 0xffffffffu;
+
+    if (!pdev)
+        return PCI_ERS_RESULT_DISCONNECT;
+
+    nvl = pci_get_drvdata(pdev);
+    if (!nvl)
+        return PCI_ERS_RESULT_DISCONNECT;
+
+    nv = NV_STATE_PTR(nvl);
+    bar0_phys = nv->bars[NV_GPU_BAR_INDEX_REGS].cpu_address;
+    if (bar0_phys == 0)
+    {
+        NV_DEV_PRINTF(NV_DBG_ERRORS, nv,
+            "AORUS Lever M-recover: slot_reset — bar0_phys=0; cannot verify; "
+            "DISCONNECT\n");
+        return PCI_ERS_RESULT_DISCONNECT;
+    }
+
+    tmp_map = ioremap(bar0_phys, PAGE_SIZE);
+    if (tmp_map)
+    {
+        pmc_boot_0 = ioread32(tmp_map);
+        iounmap(tmp_map);
+    }
+
+    if (pmc_boot_0 == 0xffffffffu)
+    {
+        NV_DEV_PRINTF(NV_DBG_ERRORS, nv,
+            "AORUS Lever M-recover: slot_reset — PMC_BOOT_0=0xffffffff "
+            "(bus still down); DISCONNECT\n");
+        if (nvl->lever_m)
+        {
+            atomic_inc(&nvl->lever_m->surrender_count);
+            tb_egpu_lever_m_emit_uevent(pdev, "PERMANENT_FAIL");
+        }
+        return PCI_ERS_RESULT_DISCONNECT;
+    }
+
+    NV_DEV_PRINTF(NV_DBG_ERRORS, nv,
+        "AORUS Lever M-recover: slot_reset — PMC_BOOT_0=0x%08x; RECOVERED\n",
+        pmc_boot_0);
+    return PCI_ERS_RESULT_RECOVERED;
+}
+EXPORT_SYMBOL(tb_egpu_lever_m_slot_reset);
+
+/* Commit 3 (H4): pci_error_handlers resume helper.
+ *
+ * Called from nv_pci_resume() in nv-pci.c after slot_reset returned
+ * RECOVERED. This is where we declare success: increment success_count,
+ * reset attempt_count to 0, emit TB_EGPU_GPU_STATE=READY uevent.
+ *
+ * Patch 0024 v1 does NOT re-enter rm_init_adapter from this callback —
+ * doing so safely requires preserving CUDA context state across reset,
+ * which is M-preserve scope. v1 successful recovery is "GPU is alive
+ * on the bus again"; userspace must rebind to use it.
+ */
+void tb_egpu_lever_m_slot_reset_resume(struct pci_dev *pdev)
+{
+    nv_linux_state_t *nvl;
+
+    if (!pdev)
+        return;
+
+    nvl = pci_get_drvdata(pdev);
+    if (!nvl || !nvl->lever_m)
+        return;
+
+    atomic_inc(&nvl->lever_m->success_count);
+    atomic_set(&nvl->lever_m->attempt_count, 0);
+
+    nv_printf(NV_DBG_ERRORS,
+        "AORUS Lever M-recover: resume — success_count=%d, attempt_count "
+        "reset to 0; emitting READY\n",
+        atomic_read(&nvl->lever_m->success_count));
+
+    tb_egpu_lever_m_emit_uevent(pdev, "READY");
+}
+EXPORT_SYMBOL(tb_egpu_lever_m_slot_reset_resume);
