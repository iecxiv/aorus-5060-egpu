# Pin the AORUS RTX 5090 eGPU PCI path out of runtime D3cold.
#
# Targets:
#   8086:7ec4 - Intel Thunderbolt 4 NHI host controller
#   8086:5786 - Intel JHL9480 Thunderbolt 4 retimer/bridge upstream
#   10de:2b85 - NVIDIA RTX 5090 (GB202) GPU function
#   10de:22e8 - NVIDIA RTX 5090 (GB202) HDMI audio function
#
# For each: power/control=on (no autosuspend) and d3cold_allowed=0 (no D3cold).
# Without this, an idle eGPU can transition into D3cold; coming back out over
# the TB tunnel is unreliable and was a contributor to early GPU "fallen off the
# bus" / "Unable to change power state from D3cold to D0" hangs.

ACTION=="add|bind|change", SUBSYSTEM=="pci", ATTR{vendor}=="0x8086", ATTR{device}=="0x7ec4", TEST=="power/control", ATTR{power/control}="on"
ACTION=="add|bind|change", SUBSYSTEM=="pci", ATTR{vendor}=="0x8086", ATTR{device}=="0x7ec4", TEST=="d3cold_allowed", ATTR{d3cold_allowed}="0"
ACTION=="add|bind|change", SUBSYSTEM=="pci", ATTR{vendor}=="0x8086", ATTR{device}=="0x5786", TEST=="power/control", ATTR{power/control}="on"
ACTION=="add|bind|change", SUBSYSTEM=="pci", ATTR{vendor}=="0x8086", ATTR{device}=="0x5786", TEST=="d3cold_allowed", ATTR{d3cold_allowed}="0"
ACTION=="add|bind|change", SUBSYSTEM=="pci", ATTR{vendor}=="0x10de", ATTR{device}=="0x2b85", TEST=="power/control", ATTR{power/control}="on"
ACTION=="add|bind|change", SUBSYSTEM=="pci", ATTR{vendor}=="0x10de", ATTR{device}=="0x2b85", TEST=="d3cold_allowed", ATTR{d3cold_allowed}="0"
ACTION=="add|bind|change", SUBSYSTEM=="pci", ATTR{vendor}=="0x10de", ATTR{device}=="0x22e8", TEST=="power/control", ATTR{power/control}="on"
ACTION=="add|bind|change", SUBSYSTEM=="pci", ATTR{vendor}=="0x10de", ATTR{device}=="0x22e8", TEST=="d3cold_allowed", ATTR{d3cold_allowed}="0"
