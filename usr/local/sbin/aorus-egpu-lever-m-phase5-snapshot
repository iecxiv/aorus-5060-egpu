#!/usr/bin/env bash
# aorus-egpu-lever-m-phase5-snapshot — Phase 5 evidence collection.
#
# Captures Lever M-recover state per boot for the n>=10 PROVEN gate
# (docs/service-retirement-roadmap.md). Runs as a systemd oneshot on
# boot, after the loader + persistenced + L4 helper have had a chance
# to settle. Idempotent — single file per boot, named by boot ID.
#
# Output: archive/phase5-evidence/<boot-iso>.log

set -u

# shellcheck source=/usr/local/lib/aorus-egpu/common.sh
source /usr/local/lib/aorus-egpu/common.sh

REPO_ROOT="${REPO_ROOT:-/root/aorus-5090-egpu}"
EVIDENCE_DIR="$REPO_ROOT/archive/phase5-evidence"
GPU_BDF="${EGPU_BDF:-0000:04:00.0}"
SYSFS="/sys/bus/pci/devices/$GPU_BDF"
NOW="$(date -Iseconds)"

# Use /proc/stat btime — the kernel's authoritative boot epoch. Constant
# for the lifetime of the boot, so re-runs of this script within the
# same boot collapse onto the same filename and the existence check
# below makes the script idempotent.
boot_epoch=$(awk '/^btime / {print $2}' /proc/stat)
BOOT_TAG="$(date -d "@$boot_epoch" +%Y-%m-%dT%H%M%S)"
LOG="$EVIDENCE_DIR/$BOOT_TAG.log"

mkdir -p "$EVIDENCE_DIR"

# If the snapshot for this boot already exists, exit — don't clobber
# (e.g. on manual re-run of the systemd unit).
if [[ -e "$LOG" ]]; then
    echo "snapshot already exists: $LOG"
    exit 0
fi

read_or_dash() { [[ -r "$1" ]] && cat "$1" 2>/dev/null || echo "-"; }

{
    echo "# Lever M-recover Phase 5 evidence snapshot"
    echo "snapshot_time: $NOW"
    echo "boot_time:     $(date -Iseconds -d "@$boot_epoch") (btime=$boot_epoch)"
    echo "uptime_s:      $(awk '{print int($1)}' /proc/uptime)"
    echo "kernel:        $(uname -r)"
    echo
    echo "## Module identity"
    if modinfo nvidia >/dev/null 2>&1; then
        modinfo nvidia 2>/dev/null | grep -E "^(version|srcversion):"
    else
        echo "(nvidia module not loaded)"
    fi
    echo
    echo "## Kill-switch state (H3)"
    echo "file:    $(read_or_dash /var/lib/aorus-egpu/lever-m-killswitch)"
    echo "runtime: $(read_or_dash /sys/module/nvidia/parameters/NVreg_AorusLeverMRecoverEnable)"
    echo
    echo "## M-recover counters"
    if [[ -d "$SYSFS" ]]; then
        echo "fires:        $(read_or_dash $SYSFS/aorus_lever_m_fires)"
        echo "successes:    $(read_or_dash $SYSFS/aorus_lever_m_successes)"
        echo "surrenders:   $(read_or_dash $SYSFS/aorus_lever_m_surrenders)"
        echo "last_fire_jf: $(read_or_dash $SYSFS/aorus_lever_m_last_fire_jiffies)"
    else
        echo "(GPU at $GPU_BDF not present in sysfs)"
    fi
    echo
    echo "## post-rmInit-{OK,FAIL} count this boot"
    ok=$(dmesg 2>/dev/null | grep -c "post-rmInit-OK")
    fail=$(dmesg 2>/dev/null | grep -c "post-rmInit-FAIL")
    echo "post-rmInit-OK:   ${ok:-0}"
    echo "post-rmInit-FAIL: ${fail:-0}"
    echo
    echo "## Close-path activity this boot (Patch 0029)"
    close_entry=$(dmesg 2>/dev/null | grep -c "\[CLOSE\]: site=close-entry")
    pre_stop=$(dmesg 2>/dev/null | grep -c "\[CLOSE\]: site=pre-stop")
    post_shutdown=$(dmesg 2>/dev/null | grep -c "\[CLOSE\]: site=post-shutdown")
    close_exit=$(dmesg 2>/dev/null | grep -c "\[CLOSE\]: site=close-exit")
    last_close=$(dmesg 2>/dev/null | grep -c "(LAST-CLOSE)")
    mmio_enabled_cb=$(dmesg 2>/dev/null | grep -c "mmio_enabled callback fired")
    cor_error_cb=$(dmesg 2>/dev/null | grep -c "cor_error_detected callback fired")
    echo "close-entry:           ${close_entry:-0}"
    echo "pre-stop:              ${pre_stop:-0}"
    echo "post-shutdown:         ${post_shutdown:-0}"
    echo "close-exit:            ${close_exit:-0}"
    echo "last-close events:     ${last_close:-0}  (full DIAG+AER snapshot fired)"
    echo "mmio_enabled callback: ${mmio_enabled_cb:-0}"
    echo "cor_error_detected:    ${cor_error_cb:-0}"
    echo
    echo "## M-recover dmesg events (this boot, chronological)"
    if dmesg 2>/dev/null | grep -qiE "AORUS Lever M-recover.*(scheduling recovery|RECOVERED|emitting READY|PERMANENT_FAIL|rate-limited|surrender after|WPR2 DETECTED|kill-switch file engaged|post-rmInit-OK observed|TestForceTrigger=1|\[CLOSE\]:|mmio_enabled callback|cor_error_detected callback)"; then
        dmesg 2>/dev/null | grep -iE "AORUS Lever M-recover.*(scheduling recovery|RECOVERED|emitting READY|PERMANENT_FAIL|rate-limited|surrender after|WPR2 DETECTED|kill-switch file engaged|post-rmInit-OK observed|TestForceTrigger=1|\[CLOSE\]:|mmio_enabled callback|cor_error_detected callback)" | sed 's/^/  /'
    else
        echo "  (no M-recover events this boot)"
    fi
    echo
    echo "## L4 helper events for this boot (from wpr2-recoveries.log)"
    if [[ -r /var/lib/aorus-egpu/wpr2-recoveries.log ]]; then
        boot_iso="$(date -Iseconds -d "@$boot_epoch")"
        # Filter to ISO-timestamped CSV rows only (skip stray non-CSV
        # lines like nvidia-smi error spew that the helper sometimes
        # tees into the log) AND only this-boot's entries.
        matches="$(awk -F, -v cutoff="$boot_iso" '$1 ~ /^[0-9]{4}-[0-9]{2}-[0-9]{2}T/ && $1 >= cutoff' /var/lib/aorus-egpu/wpr2-recoveries.log)"
        if [[ -n "$matches" ]]; then
            printf '%s\n' "$matches" | sed 's/^/  /'
        else
            echo "  (no L4 helper events this boot)"
        fi
    else
        echo "  (wpr2-recoveries.log absent)"
    fi
    echo
    echo "## GPU functional check"
    if command -v nvidia-smi >/dev/null 2>&1; then
        nvidia-smi -L 2>&1 | head -3 | sed 's/^/  /'
    else
        echo "  (nvidia-smi unavailable)"
    fi
    echo
    echo "## Verdict"
    fires=$(read_or_dash "$SYSFS/aorus_lever_m_fires")
    successes=$(read_or_dash "$SYSFS/aorus_lever_m_successes")
    surrenders=$(read_or_dash "$SYSFS/aorus_lever_m_surrenders")
    if [[ "$fires" =~ ^[0-9]+$ ]] && [[ "$fires" -gt 0 ]]; then
        if [[ "$surrenders" =~ ^[0-9]+$ ]] && [[ "$surrenders" -gt 0 ]]; then
            echo "M-RECOVER-FIRED-AND-SURRENDERED: fires=$fires successes=$successes surrenders=$surrenders"
            echo "(does NOT count toward n>=10 PROVEN — recovery did not succeed end-to-end)"
        elif [[ "$successes" =~ ^[0-9]+$ ]] && [[ "$successes" -gt 0 ]]; then
            echo "M-RECOVER-FIRED-OK: fires=$fires successes=$successes surrenders=$surrenders"
            echo "(counts toward n>=10 PROVEN if WPR2 was actually stuck on this boot — verify by checking post-rmInit-FAIL was non-zero)"
        else
            echo "M-RECOVER-FIRED-INFLIGHT: fires=$fires successes=$successes surrenders=$surrenders"
            echo "(snapshot may have run mid-recovery; re-check after settling)"
        fi
    else
        echo "M-RECOVER-NOT-FIRED: no recovery needed this boot (clean cold-cold)"
    fi
} > "$LOG"

echo "wrote $LOG"
exit 0
