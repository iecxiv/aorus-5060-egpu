#!/usr/bin/env bash
# aorus-egpu-detect-config — auto-detect TB-attached NVIDIA eGPU topology
# and write /etc/aorus-egpu/config.env.
#
# Sourced by all egpu-stack helpers (compute-load, bridge-link-cap,
# disable-audio, status, observability, lever-m, probes, etc.) so the
# stack can run on any host with a TB-attached NVIDIA GPU without
# editing each helper individually.
#
# Idempotent. Safe to re-run after hardware changes (port swap, GPU
# swap, enclosure swap). Writes config.env atomically; previous file
# is moved to config.env.previous.
#
# Detection scope: TB-attached NVIDIA GPU. Detection assumptions:
#   - eGPU is the FIRST NVIDIA display/3D controller found on PCI
#     (vendor 0x10de, class 0x0300 VGA or 0x0302 3D)
#   - Paired audio function shares the same bus.dev with function != 0
#     (vendor 0x10de, class 0x0403 audio)
#   - Parent PCIe bridge is the GPU's immediate upstream device
#   - Host-side TB controller(s) are upstream PCIe devices with class
#     0x0c03 (USB controller / TB host)
#
# Override: any value in the generated config.env can be edited
# manually; re-running this script will overwrite (with the prior
# version saved as config.env.previous). To pin specific values, set
# them via environment vars when invoking:
#   EGPU_BDF=0000:04:00.0 sudo aorus-egpu-detect-config
#
# Usage:
#   sudo /usr/local/sbin/aorus-egpu-detect-config         # detect + write
#   sudo /usr/local/sbin/aorus-egpu-detect-config --show  # detect, print only
#   sudo /usr/local/sbin/aorus-egpu-detect-config --diff  # show diff vs current

set -uo pipefail

CONFIG_DIR="${CONFIG_DIR:-/etc/aorus-egpu}"
CONFIG_FILE="${CONFIG_FILE:-${CONFIG_DIR}/config.env}"
NVIDIA_VENDOR="0x10de"

mode="write"
case "${1:-}" in
    --show) mode="show" ;;
    --diff) mode="diff" ;;
    "")     mode="write" ;;
    *)      echo "usage: $0 [--show|--diff]" >&2; exit 1 ;;
esac

read_field() { [[ -r "$1" ]] && cat "$1" 2>/dev/null || echo "" ; }

# 1. Find first NVIDIA display/3D controller
gpu_dev=""
for dev in /sys/bus/pci/devices/*; do
    v="$(read_field "$dev/vendor")"
    cls="$(read_field "$dev/class")"
    [[ "$v" == "$NVIDIA_VENDOR" ]] || continue
    case "${cls:0:6}" in
        "0x0300"|"0x0302") gpu_dev="$dev"; break ;;
    esac
done

if [[ -z "$gpu_dev" ]]; then
    echo "aorus-egpu-detect-config: no NVIDIA GPU found on PCI (vendor 0x10de, class 0x030x)" >&2
    exit 1
fi

gpu_real="$(readlink -f "$gpu_dev")"
gpu_bdf="$(basename "$gpu_real")"
gpu_vendor="$(read_field "$gpu_dev/vendor")"
gpu_device="$(read_field "$gpu_dev/device")"
gpu_class="$(read_field "$gpu_dev/class")"

# Honour env override if provided
gpu_bdf="${EGPU_BDF:-$gpu_bdf}"

# 2. Paired audio function — same bus.dev, function != 0
gpu_bus_dev="${gpu_bdf%.*}"
audio_bdf=""
audio_device_id=""
for dev in /sys/bus/pci/devices/${gpu_bus_dev}.*; do
    [[ -d "$dev" ]] || continue
    [[ "$(basename "$dev")" != "$gpu_bdf" ]] || continue
    v="$(read_field "$dev/vendor")"
    cls="$(read_field "$dev/class")"
    if [[ "$v" == "$NVIDIA_VENDOR" && "${cls:0:6}" == "0x0403" ]]; then
        audio_bdf="$(basename "$dev")"
        audio_device_id="$(read_field "$dev/device")"
        break
    fi
done

# 3. Parent PCIe bridge (immediate upstream)
parent_real="$(dirname "$gpu_real")"
parent_bridge=""
if [[ -r "$parent_real/vendor" ]]; then
    parent_bridge="$(basename "$parent_real")"
fi

# 4. Walk upstream to find TB host controller(s) — class 0x0c03
tb_host_devs=()
path="$parent_real"
while [[ "$path" != "/" && "$path" != "/sys" && "$path" != "/sys/devices" ]]; do
    path="$(dirname "$path")"
    [[ -r "$path/vendor" && -r "$path/class" ]] || continue
    cls="$(read_field "$path/class")"
    case "${cls:0:6}" in
        "0x0c03"|"0x0604")
            v="$(read_field "$path/vendor")"
            d="$(read_field "$path/device")"
            tb_host_devs+=("${v}:${d}")
            ;;
    esac
done

# 5. Generate config text
config_text=$(cat <<EOF
# /etc/aorus-egpu/config.env — auto-generated by aorus-egpu-detect-config
#
# Sourced by every egpu-stack helper. Re-run aorus-egpu-detect-config to
# refresh after hardware changes; the previous file is preserved as
# config.env.previous. Manual edits are overwritten on re-run.
#
# Detected: $(date -Iseconds) on $(uname -n) (kernel $(uname -r))
# Detection script: /usr/local/sbin/aorus-egpu-detect-config

# --- eGPU identification ---
EGPU_VENDOR_ID="$gpu_vendor"
EGPU_DEVICE_ID="$gpu_device"
EGPU_CLASS="$gpu_class"
EGPU_BDF="$gpu_bdf"

# --- Audio function (HDMI audio paired with the GPU) ---
EGPU_AUDIO_DEVICE_ID="$audio_device_id"
EGPU_AUDIO_BDF="$audio_bdf"

# --- Parent PCIe bridge (target of bridge-link-cap) ---
EGPU_BRIDGE_BDF="$parent_bridge"

# --- Host-side upstream PCIe / TB chain (vendor:device pairs, root-port to GPU-bridge) ---
# Used by udev rules + status.sh to apply PM policy across the path.
TB_HOST_VENDOR_DEVICES=(
$(for vd in "${tb_host_devs[@]}"; do printf '    "%s"\n' "$vd"; done)
)

# --- Lever H17 bridge link-cap settings (LnkCtl2) ---
# Empirically validated 2026-05-08: this hardware requires Gen3 cap
# with Hardware Autonomous Speed Disable to prevent GSP_LOCKDOWN
# cascades. See docs/services/bridge-link-cap.md for test history.
# Different hardware MAY allow Gen4 (uncapped) or require Gen2 — use
# tools/close-path-probe.sh to validate any change.
LINK_CAP_TARGET_SPEED="0x3"     # 1=Gen1 2=Gen2 3=Gen3 4=Gen4
LINK_CAP_HW_AUTO_DISABLE="1"    # LnkCtl2 bit 5 (1=disable autonomous shifts)
EOF
)

case "$mode" in
    show)
        echo "$config_text"
        ;;
    diff)
        if [[ -e "$CONFIG_FILE" ]]; then
            diff -u "$CONFIG_FILE" <(echo "$config_text") || true
        else
            echo "no existing config at $CONFIG_FILE; would write:"
            echo "$config_text"
        fi
        ;;
    write)
        if [[ "$EUID" -ne 0 ]]; then
            echo "write mode requires root" >&2
            exit 1
        fi
        mkdir -p "$CONFIG_DIR"
        if [[ -e "$CONFIG_FILE" ]]; then
            cp -a "$CONFIG_FILE" "$CONFIG_FILE.previous"
        fi
        printf '%s\n' "$config_text" > "$CONFIG_FILE.new"
        mv -f "$CONFIG_FILE.new" "$CONFIG_FILE"
        echo "wrote $CONFIG_FILE"
        echo ""
        cat "$CONFIG_FILE"
        ;;
esac
